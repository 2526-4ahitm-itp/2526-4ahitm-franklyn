{
  "name": "franklyn-proctor",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "run-s type-check build-only",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "lint": "eslint . --fix --cache",
    "lint:check": "eslint . --cache",
    "licensee": "licensee --errors-only",
    "format": "prettier --write src/",
    "postinstall": "node -e \"const fs = require('fs'); const file = 'node_modules/licensee/index.js'; if (fs.existsSync(file)) { let c = fs.readFileSync(file, 'utf8'); c = c.replace('!dependency.isProjectRoot', '!dependency.isProjectRoot && dependency.package && dependency.package.name'); fs.writeFileSync(file, c); }\""
  },
  "dependencies": {
    "@bufbuild/buf": "^1.69.0",
    "@bufbuild/protobuf": "^2.12.0",
    "@bufbuild/protoc-gen-es": "^2.12.0",
    "@pinia/colada": "1.3.0",
    "bootstrap-icons": "^1.13.1",
    "dompurify": "^3.4.5",
    "keycloak-js": "^26.2.3",
    "markdown-it": "^14.2.0",
    "pinia": "^3.0.3",
    "pinia-plugin-persistedstate": "^4.7.1",
    "reka-ui": "^2.9.6",
    "villus": "3.5.2",
    "vue": "^3.5.22",
    "vue-i18n": "^11.4.3",
    "vue-router": "^4.6.3"
  },
  "devDependencies": {
    "@tsconfig/node22": "^22.0.2",
    "@types/dompurify": "^3.2.0",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.18.11",
    "@typescript-eslint/eslint-plugin": "^8.46.4",
    "@typescript-eslint/parser": "^8.46.4",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.6.0",
    "@vue/tsconfig": "^0.8.1",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-vue": "^10.5.1",
    "jiti": "^2.6.1",
    "licensee": "^12.0.1",
    "npm-run-all2": "^8.0.4",
    "prettier": "^3.6.2",
    "typescript": "~5.9.0",
    "vite": "^7.1.11",
    "vite-plugin-vue-devtools": "^8.0.3",
    "vue-tsc": "^3.1.1"
  }
}
