@startuml release-0-6-0
skinparam backgroundColor transparent
skinparam defaultFontColor #ECEFF4
skinparam ArrowColor #D8DEE9
skinparam DefaultBorderColor #4C566A
skinparam nodeBackgroundColor #3B4252
skinparam componentBackgroundColor #434C5E
skinparam componentStyle rectangle
skinparam cloudBackgroundColor #3B4252
skinparam cloudFontColor #ECEFF4

title v0.6.0 Release Trigger

actor Developer
cloud "GitHub" as GH {
  component "main branch" as Main
  component "manual dispatch" as Manual
  component "Release Workflow\n(release.yaml)" as Release {
    component "check commit for\n[dev|minor|major|patch|rc]" as Check
    component "increment ./VERSION\nwith custom semver script" as Bump
  }
  component "commit + tag vX.Y.Z" as Tag
}

Developer --> Main : push to main
Developer --> Manual : workflow_dispatch
Main --> Release : push
Manual --> Release : dispatch
Release --> Check
Check --> Bump
Bump --> Tag

@enduml
