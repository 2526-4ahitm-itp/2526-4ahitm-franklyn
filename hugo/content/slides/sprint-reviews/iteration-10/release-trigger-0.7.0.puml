@startuml release-0-7-0
skinparam backgroundColor transparent
skinparam defaultFontColor #ECEFF4
skinparam ArrowColor #D8DEE9
skinparam DefaultBorderColor #4C566A
skinparam nodeBackgroundColor #3B4252
skinparam componentBackgroundColor #434C5E
skinparam componentStyle rectangle
skinparam cloudBackgroundColor #3B4252
skinparam cloudFontColor #ECEFF4

title v0.7.0 Release Trigger

actor Developer
cloud "GitHub" as GH {
  component "Git tag v*" as Tag
  component "Release Workflow\n(release.yaml)" as Release {
    component "verify tag == ./VERSION" as Verify
    component "build artifacts" as Build
  }
}

Developer --> Tag : create tag
Tag --> Release
Verify --> Build

@enduml
