scalar DateTime
scalar BigInteger

"Mutation root"
type Mutation {
  createTest(test: TestInput): Test
  deleteTest(id: String): String
  updateTest(id: String, test: TestInput): Test
}

"Query root"
type Query {
  testId(id: String): Test
  tests: [Test]
}

type Test {
  "ISO-8601"
  endTime: DateTime
  id: String
  "ISO-8601"
  startTime: DateTime
  teacherId: String
  title: String
}

input TestInput {
  "ISO-8601"
  endTime: DateTime
  "ISO-8601"
  startTime: DateTime
  title: String
}
